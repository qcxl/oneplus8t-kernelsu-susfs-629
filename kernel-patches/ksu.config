# KernelSU config for OnePlus 8T (kebab) kernel 4.19 - PURE KSU (no SUSFS)
# Step 0: Verify KSU + manual hook boots before adding SUSFS

# --- KernelSU core ---
CONFIG_KSU=y

# Manual hook is preferred over kprobes for SM8250 4.19 trees
CONFIG_KSU_MANUAL_HOOK=y
# CONFIG_KSU_KPROBES_HOOK is not set

# --- SUSFS disabled for Step 0 (pure KSU verification) ---
# CONFIG_KSU_SUSFS is not set

# --- Required for Zygisk Next module compatibility ---
CONFIG_KPROBES=y
CONFIG_HAVE_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y

# Disable module signature checks that block module mounts
# CONFIG_MODULE_SIG_FORCE is not set
CONFIG_KERNEL_GZIP=y
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y
